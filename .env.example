# Local Ollama — used when running individual steps directly (make download, etc.)
# When running via Docker (make run), compose.yaml overrides LLM_BASE_URL to
# http://ollama:11434/v1 automatically so you don't need to change this.
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=gemma4:e2b

# OpenAI example
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Pagination — how many books to scrape per run.
# PAGE_SIZE controls results per listing request (default: 10, max the site supports: 10).
# MAX_BOOKS caps the total across all pages; 0 means no limit (scrape everything).
# PAGE_SIZE=10
# MAX_BOOKS=50
